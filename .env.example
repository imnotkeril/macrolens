# Copy to ".env" here (project root) for docker compose + optional tooling.
# If you run uvicorn from backend/ only, also copy the same keys into backend/.env (see backend/.env.example).

# Optional: set to project root path if Docker uses wrong path (e.g. after moving project).
# Use . for default (run docker compose from project root).
# Example: PROJECT_ROOT=E:\Dev\Python\macrolens
PROJECT_ROOT=.

FRED_API_KEY=

# How far back FRED + Yahoo historical bulk loads go (rolling window from today).
# Examples: 16 ≈ from ~2010, 26 ≈ from ~2000 (depends on current year). After changing, wipe DB or re-run full refresh if counts already high.
HISTORICAL_YEARS=10

# Forecast Lab: first month-end included in training features (needs indicator/yield history in DB for this range).
FORECAST_LAB_DATE_FROM=2008-01-01
# Default summary as_of: align to last completed month-end (when no align_month_end query). true|false
FORECAST_LAB_SUMMARY_ALIGN_MONTH_END=false
# GBDT/HMM target: rule_v1 | asset_implied_v1
FORECAST_LAB_LABEL_MODE=asset_implied_v1
# After POST /api/forecast-lab/log-snapshot, upsert memory document
FORECAST_LAB_MEMORY_INGEST_ENABLED=false
# GET /summary includes Navigator + Cycle (Radar) cross-check block
FORECAST_LAB_INCLUDE_DASHBOARD_CONTEXT=true
# GBDT: sample_weight from asset pair agreement (asset_implied_v1); 0 = off
FORECAST_LAB_AUXILIARY_ASSET_WEIGHT=0.35
# Phase ensemble: fourth expert = Cycle Radar → quadrant prior
FORECAST_LAB_ENSEMBLE_INCLUDE_CYCLE=true
# Train recession_xgb.json from recession_labels (forward 12m)
FORECAST_LAB_TRAIN_RECESSION_MODEL=true

# Memory: auto | hash | openai
MEMORY_EMBEDDING_BACKEND=auto

# Claude (Anthropic) — generation for agents. This is not ChatGPT; ChatGPT keys go unused unless you add OpenAI chat later.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OpenAI — only embeddings for memory (text-embedding-*), not GPT chat in current code.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_TIMEOUT_SECONDS=120
EMBEDDING_TIMEOUT_SECONDS=60

# Telegram (optional; set TELEGRAM_INGESTION_ENABLED=true after configuring).
# For channel history, use a user session file (Telethon) on TELEGRAM_SESSION_PATH; bot tokens alone often cannot read arbitrary channels.
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_SESSION_PATH=
TELEGRAM_CHANNEL_WHITELIST=
TELEGRAM_INGESTION_ENABLED=false
TELEGRAM_INGEST_MAX_MESSAGES=80

# Frontend (Docker): Next.js rewrites /api to the backend. In docker-compose this is set on the frontend service.
# When running `npm run dev` on the host with API on localhost:8000, the default rewrite target is http://127.0.0.1:8000.
# BACKEND_INTERNAL_URL=http://backend:8000
