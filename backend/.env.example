# Copy to backend/.env and fill in values. Backend loads .env from the working directory (usually backend/).
# For docker compose, prefer a single .env in the project root (same variable names).

DATABASE_URL=postgresql+asyncpg://macrolens:macrolens_secret@localhost:5432/macrolens
REDIS_URL=redis://localhost:6379/0
FRED_API_KEY=

# CORS allowed origins (comma-separated). Dev default below; in production set your
# frontend origin, e.g. https://macrolens.vercel.app. "*" allows all (disables credentials).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional CoinGecko Pro key — enables long market_chart history (days=max); empty caps at 365 days.
COINGECKO_API_KEY=

# Dev-only NDJSON debug sink. Leave EMPTY in production (no file is written when unset).
DEBUG_LOG_PATH=

# --- Agents / LLM (optional; leave empty = rule fallbacks, no external API calls) ---
# Anthropic Claude: text generation for Fed / News / Macro / Master agents
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
LLM_TIMEOUT_SECONDS=120

# OpenAI: embeddings only (memory retrieval). Not used for ChatGPT chat in this project.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT_SECONDS=60

# Memory: auto (use OpenAI embeddings if OPENAI_API_KEY set) | hash | openai
MEMORY_EMBEDDING_BACKEND=auto

# --- Telegram news ingest (optional) ---
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_SESSION_PATH=
TELEGRAM_CHANNEL_WHITELIST=
TELEGRAM_INGESTION_ENABLED=false
TELEGRAM_INGEST_MAX_MESSAGES=80
